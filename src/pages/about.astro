---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us | Siraj Mia Memorial Model School" description="Learn about our founding, mission, vision, and commitment to quality education at a reasonable price.">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-500 via-primary-600 to-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white rounded-full translate-y-1/3 -translate-x-1/4"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-3xl">
        <p class="text-blue-200 font-medium mb-3 tracking-wide uppercase text-sm">About SMMM School</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
          Our Story
        </h1>
        <p class="text-lg md:text-xl text-blue-100 leading-relaxed mb-8 max-w-2xl">
          Two decades of commitment to quality education, nurturing potential, and building futures at a reasonable price.
        </p>
      </div>
    </div>
  </section>

  <!-- Founding Story -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-primary-500 font-medium mb-2 uppercase tracking-wide text-sm">Our Heritage</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-6">A Legacy Founded on Vision</h2>

          <p class="text-gray-600 leading-relaxed mb-4">
            Siraj Mia Memorial Model School was established in 2005 with a noble purpose: to honour the memory of Siraj Mia, the founder's late father, by providing quality education at a reasonable price.
          </p>

          <p class="text-gray-600 leading-relaxed mb-6">
            The school was officially inaugurated on <strong>13th January 2007</strong> by <strong>Dr. Anwara Begum</strong>, the wife of <strong>Dr. Iajuddin Ahmed</strong>, who served as the President of Bangladesh. This momentous occasion marked the beginning of our journey to transform education in Badda, Dhaka.
          </p>

          <p class="text-gray-600 leading-relaxed mb-6">
            Our primary objective has remained unwavering: to provide high-quality education at an affordable price. We believe every child deserves access to excellent education regardless of their financial background. Through dedicated teaching, modern infrastructure, and a supportive learning environment, we nurture the potential within every student.
          </p>

          <p class="text-gray-600 leading-relaxed">
            Today, nearly two decades later, SMMM School stands as a beacon of educational excellence in the community, with a track record of academic achievement, character development, and social responsibility.
          </p>
        </div>
        <div class="rounded-2xl aspect-[4/3] overflow-hidden">
          <img src="/images/home/inauguration.jpg" alt="School inauguration ceremony with Dr. Anwara Begum, 13 January 2007" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Mission & Vision</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Our guiding principles that shape everything we do</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Mission Card -->
        <div class="bg-white rounded-xl shadow-lg p-8">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Our Mission</h3>
          <p class="text-gray-600 leading-relaxed">
            To provide high-quality education at reasonable price while nurturing the intellectual, moral, and physical development of every student. We are committed to fostering critical thinking, creativity, and character excellence in a supportive and inclusive environment.
          </p>
        </div>

        <!-- Vision Card -->
        <div class="bg-white rounded-xl shadow-lg p-8">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Our Vision</h3>
          <p class="text-gray-600 leading-relaxed">
            To be the leading educational institution in Badda, recognized for upholding academic excellence, discipline, and community service. We aspire to produce responsible global citizens who contribute positively to society and excel in their chosen fields.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Leadership Team -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Our Leadership</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Meet the dedicated individuals guiding our school's mission</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">

        <!-- Founder Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 text-center">
          <img src="/images/team/founder.jpg" alt="Md. Monir Hossain - Founder" class="w-24 h-24 rounded-full object-cover mx-auto mb-6" />
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-1">Md. Monir Hossain</h3>
          <p class="text-primary-600 font-medium mb-3 text-sm">Founder</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Philanthropist who established the school with the prime philosophy of delivering quality education and good character building.
          </p>
        </div>

        <!-- Chairman Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 text-center">
          <img src="/images/team/chairman.jpg" alt="Md. Rafy Hossain - Chairman" class="w-24 h-24 rounded-full object-cover mx-auto mb-6" />
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-1">Md. Rafy Hossain</h3>
          <p class="text-primary-600 font-medium mb-3 text-sm">Chairman</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Accredited Civil-Commercial Mediator (ADR ODR International), LLB (Leeds Trinity University). Carries forward a legacy named after his grandfather, overseeing daily operations and maintaining foundational values.
          </p>
        </div>

        <!-- Principal Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 text-center">
          <img src="/images/team/principal.png" alt="Prof. Syed Abdur Razzak - Principal" class="w-24 h-24 rounded-full object-cover mx-auto mb-6" />
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-1">Prof. Syed Abdur Razzak</h3>
          <p class="text-primary-600 font-medium mb-3 text-sm">Principal</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Emphasizes co-curricular activities, BNCC training, and developing student discipline. Focused on establishing the school as a leader and quality provider to national education.
          </p>
        </div>

        <!-- Vice Principal Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 text-center">
          <img src="/images/team/vice-principal.png" alt="Md. Harun-or-Rashid Bhuyian - Vice Principal" class="w-24 h-24 rounded-full object-cover mx-auto mb-6" />
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-1">Md. Harun-or-Rashid Bhuyian</h3>
          <p class="text-primary-600 font-medium mb-3 text-sm">Vice Principal</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Prioritizes learners' interests and developing latent student qualities. Advocates for continuous nourishment of inborn qualities in an edu-friendly environment.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 md:py-24 bg-primary-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Accreditation & Certifications</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Recognized for maintaining international standards of quality education</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">

        <!-- ISO 9001:2008 -->
        <div class="bg-white rounded-xl shadow-md p-8 text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6 text-primary-500">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-heading font-bold text-gray-900 mb-2">ISO 9001:2008</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Quality Management System certification demonstrating our commitment to continuous improvement and excellence.
          </p>
          <p class="text-xs text-gray-500">Quality Management</p>
        </div>

        <!-- AJA Registrars -->
        <div class="bg-white rounded-xl shadow-md p-8 text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6 text-primary-500">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-heading font-bold text-gray-900 mb-2">AJA Registrars</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Anglo Japanese American Registrars certification validating our quality assurance and management systems.
          </p>
          <p class="text-xs text-gray-500">Registered Certifier</p>
        </div>

        <!-- UKAS Management Systems -->
        <div class="bg-white rounded-xl shadow-md p-8 text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6 text-primary-500">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-heading font-bold text-gray-900 mb-2">UKAS Management</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            UK Accreditation Service certification ensuring our management systems meet international standards.
          </p>
          <p class="text-xs text-gray-500">Accreditation Body</p>
        </div>

      </div>
      <div class="mt-12 bg-white rounded-xl shadow-md overflow-hidden">
        <img src="/images/home/certificates.jpg" alt="ISO Certification from AJA and UKAS Management Systems" class="w-full max-h-64 object-contain bg-gray-50 p-4" />
        <div class="p-6 text-center">
          <p class="text-gray-700 font-medium mb-2">Commitment to Excellence</p>
          <p class="text-gray-600 text-sm">Our certifications reflect our unwavering commitment to maintaining the highest standards of educational quality and management practices, verified by independent external bodies.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary-500 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Join Our Community</h2>
      <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">Become part of a school dedicated to academic excellence, character development, and community service.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/admissions" class="bg-white text-primary-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">Apply for Admission</a>
        <a href="/contact" class="border-2 border-white/40 px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
