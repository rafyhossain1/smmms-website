---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Admissions | Siraj Mia Memorial Model School">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-500 via-primary-600 to-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white rounded-full translate-y-1/3 -translate-x-1/4"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-3xl">
        <p class="text-blue-200 font-medium mb-3 tracking-wide uppercase text-sm">Admissions Open</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
          Join Our School
        </h1>
        <p class="text-lg md:text-xl text-blue-100 leading-relaxed mb-8 max-w-2xl">
          Start your journey with SMMM School. We provide quality education with personalized attention and modern facilities for students of all class levels.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#how-to-apply" class="bg-white text-primary-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">Learn How to Apply</a>
          <a href="/contact" class="border-2 border-white/40 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Apply Section -->
  <section id="how-to-apply" class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">How to Apply</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Follow these simple steps to apply for admission at SMMM School.</p>
      </div>
      <!-- Timeline Info -->
      <div class="bg-primary-50 rounded-2xl p-6 md:p-8 mb-12">
        <div class="grid md:grid-cols-3 gap-6 text-center">
          <div>
            <p class="text-primary-500 font-heading font-bold text-2xl mb-1">November 15</p>
            <p class="text-gray-600 text-sm">Form Distribution Begins</p>
          </div>
          <div>
            <p class="text-primary-500 font-heading font-bold text-2xl mb-1">December</p>
            <p class="text-gray-600 text-sm">Admission Test Period</p>
          </div>
          <div>
            <p class="text-primary-500 font-heading font-bold text-2xl mb-1">First Week of January</p>
            <p class="text-gray-600 text-sm">Classes Begin</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <div class="relative">
          <div class="absolute top-0 left-0 w-12 h-12 bg-primary-500 rounded-full flex items-center justify-center text-white font-heading font-bold text-lg">1</div>
          <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 pl-24 min-h-full">
            <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Collect Application Form</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Form distribution begins around November 15th each year. Contact us through phone, WhatsApp, or visit our campus to collect the application form and learn about available positions and fees.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute top-0 left-0 w-12 h-12 bg-primary-500 rounded-full flex items-center justify-center text-white font-heading font-bold text-lg">2</div>
          <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 pl-24 min-h-full">
            <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Submit & Take Admission Test</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Complete the application form and submit required documents including previous academic records. All candidates must pass an admission test to assess their academic level.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute top-0 left-0 w-12 h-12 bg-primary-500 rounded-full flex items-center justify-center text-white font-heading font-bold text-lg">3</div>
          <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8 pl-24 min-h-full">
            <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Enrollment & Classes Begin</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Successful candidates complete enrollment formalities and join our school family. Classes start in the first week of January each year.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Scholarship Section -->
  <section id="scholarship" class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <div class="inline-block bg-accent-50 text-accent-600 px-4 py-1.5 rounded-full text-sm font-semibold mb-4">
          Financial Support
        </div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Scholarship Opportunities</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">We believe financial constraints should not hinder quality education. Our comprehensive scholarship program supports deserving students.</p>
      </div>

      <!-- SMMF Scholarship Program -->
      <div class="bg-white rounded-xl shadow-lg p-8 md:p-10 mb-12">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 flex-shrink-0">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          </div>
          <div>
            <h3 class="text-2xl font-heading font-bold text-gray-900 mb-2">Siraj Mia Memorial Foundation Scholarship Program</h3>
            <p class="text-gray-600 leading-relaxed">A merit-based award providing <strong>full tuition fees for six months</strong> (July to December) to two deserving students per eligible class.</p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Eligibility -->
          <div>
            <h4 class="font-heading font-bold text-gray-900 mb-4">Eligibility Requirements</h4>
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-2 text-gray-700">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Minimum <strong>80% attendance</strong> in the current academic year
              </li>
              <li class="flex items-start gap-2 text-gray-700">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Enrolled in <strong>Class 5 through Class 9</strong>
              </li>
              <li class="flex items-start gap-2 text-gray-700">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Good behavioral record with <strong>no disciplinary issues</strong>
              </li>
              <li class="flex items-start gap-2 text-gray-700">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Strong academic performance in current year
              </li>
              <li class="flex items-start gap-2 text-gray-700">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Must pass the qualifying scholarship exam
              </li>
            </ul>
          </div>

          <!-- Process -->
          <div>
            <h4 class="font-heading font-bold text-gray-900 mb-4">Selection Process</h4>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 bg-primary-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">1</div>
                <p class="text-gray-700 text-sm">Complete the scholarship form and register for the qualifying exam</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 bg-primary-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">2</div>
                <p class="text-gray-700 text-sm">Sit for the qualifying exam in <strong>English, Bangla, and Mathematics</strong> (current year syllabus)</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 bg-primary-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">3</div>
                <p class="text-gray-700 text-sm">Selected candidates advance to an interview stage</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 bg-primary-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">4</div>
                <p class="text-gray-700 text-sm">Winners announced publicly — contact your class teacher for details</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary-500 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Ready to Apply?</h2>
      <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">Don't miss the opportunity to join SMMM School. Apply now and start your journey towards excellence.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="bg-white text-primary-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">Contact Admissions</a>
        <a href="/" class="border-2 border-white/40 px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">Back to Home</a>
      </div>
    </div>
  </section>

</BaseLayout>
