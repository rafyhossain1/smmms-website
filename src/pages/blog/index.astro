---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="News & Blog | Siraj Mia Memorial Model School">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-500 via-primary-600 to-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white rounded-full translate-y-1/3 -translate-x-1/4"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
          Latest Updates
        </h1>
        <p class="text-lg md:text-xl text-blue-100 leading-relaxed max-w-2xl">
          Stay informed about news, events, and achievements at Siraj Mia Memorial Model School.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow bg-white">
            {post.data.image ? (
              <div class="h-48 overflow-hidden">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
              </div>
            ) : (
              <div class="bg-primary-100 h-48 flex items-center justify-center text-primary-500/30">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3 text-sm text-gray-500">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="text-gray-300">|</span>
                <span>{post.data.author}</span>
              </div>
              <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">{post.data.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">
                {post.data.excerpt}
              </p>
              <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-2 text-primary-500 font-semibold hover:text-primary-600 transition-colors">
                Read more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
