---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Alumni | Siraj Mia Memorial Model School">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-500 via-primary-600 to-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white rounded-full translate-y-1/3 -translate-x-1/4"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
          Alumni Association
        </h1>
        <p class="text-lg md:text-xl text-blue-100 leading-relaxed max-w-2xl">
          Stay connected with SMMM School and fellow alumni. Network, participate in events, and give back to your school community.
        </p>
      </div>
    </div>
  </section>

  <!-- Alumni Features -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Networking Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8">
          <div class="w-16 h-16 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.856-1.487M15 10a3 3 0 11-6 0 3 3 0 016 0zM4 20h5v-2a3 3 0 00-.056-1.487M13 16h-1v-4h-1m1-4h.01M17 20h5v-2a3 3 0 00-5.856-1.487M15 10a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-3">Networking</h3>
          <p class="text-gray-600 leading-relaxed">
            Connect with fellow alumni from different batches, professions, and backgrounds. Build meaningful relationships that can last a lifetime and create professional opportunities.
          </p>
        </div>

        <!-- Events & Reunions Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8">
          <div class="w-16 h-16 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-3">Events & Reunions</h3>
          <p class="text-gray-600 leading-relaxed">
            Participate in exclusive alumni events, reunions, and gatherings. Celebrate milestones, reconnect with classmates, and create new memories together.
          </p>
        </div>

        <!-- Give Back Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8">
          <div class="w-16 h-16 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-3">Give Back</h3>
          <p class="text-gray-600 leading-relaxed">
            Support the school through scholarships, mentorship programs, and donations. Help shape the future of current students and strengthen the SMMM community.
          </p>
        </div>

        <!-- Stay Updated Card -->
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-8">
          <div class="w-16 h-16 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-3">Stay Updated</h3>
          <p class="text-gray-600 leading-relaxed">
            Receive news about school achievements, alumni success stories, and upcoming events. Stay informed about what's happening at your alma mater.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <section class="py-16 md:py-20 bg-primary-50">
    <div class="max-w-4xl mx-auto px-4 text-center bg-white rounded-2xl shadow-lg p-8 md:p-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Join the Alumni Network</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">
        Be part of a thriving community of SMMM School alumni. Register today to access exclusive events, networking opportunities, and updates.
      </p>
      <a href="/contact" class="inline-block bg-primary-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-600 transition-colors">
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
