---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Academics | Siraj Mia Memorial Model School">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-500 via-primary-600 to-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white rounded-full translate-y-1/3 -translate-x-1/4"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-3xl">
        <p class="text-blue-200 font-medium mb-3 tracking-wide uppercase text-sm">Quality Education • Bangladesh Curriculum</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
          Academic Excellence
        </h1>
        <p class="text-lg md:text-xl text-blue-100 leading-relaxed mb-8 max-w-2xl">
          Comprehensive curriculum with modern teaching methods, 100% SSC pass rate, and specialized BNCC training program.
        </p>
      </div>
    </div>
  </section>

  <!-- Curriculum Section -->
  <section id="curriculum" class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Curriculum</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Bangladesh National Curriculum with 100% SSC Pass Rate</p>
      </div>

      <div class="bg-primary-50 rounded-2xl p-8 md:p-12 mb-10">
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Our Approach</h3>
            <p class="text-gray-700 mb-4 leading-relaxed">
              We follow the Bangladesh National Curriculum designed to develop critical thinking, creativity, and practical skills in students. Our comprehensive academic program is designed to prepare students for excellence at all levels.
            </p>
            <p class="text-gray-700 leading-relaxed">
              With a proven track record of 100% SSC pass rate, our teaching methodology combines traditional excellence with modern pedagogical approaches.
            </p>
          </div>
          <div>
            <h3 class="text-2xl font-heading font-bold text-gray-900 mb-6">Core Subjects</h3>
            <div class="flex flex-wrap gap-3">
              <span class="bg-primary-500 text-white px-4 py-2 rounded-full text-sm font-medium">Bangla</span>
              <span class="bg-primary-600 text-white px-4 py-2 rounded-full text-sm font-medium">English</span>
              <span class="bg-primary-700 text-white px-4 py-2 rounded-full text-sm font-medium">Mathematics</span>
              <span class="bg-accent-500 text-white px-4 py-2 rounded-full text-sm font-medium">Science</span>
              <span class="bg-blue-500 text-white px-4 py-2 rounded-full text-sm font-medium">ICT</span>
              <span class="bg-indigo-500 text-white px-4 py-2 rounded-full text-sm font-medium">Social Studies</span>
              <span class="bg-purple-500 text-white px-4 py-2 rounded-full text-sm font-medium">Religious Studies</span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <div class="text-4xl font-bold text-primary-500 mb-2">100%</div>
          <h3 class="font-heading font-bold text-gray-900 mb-2">SSC Pass Rate</h3>
          <p class="text-gray-600 text-sm">Consistent excellence in board examinations with distinction results</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <div class="text-4xl font-bold text-primary-500 mb-2">7</div>
          <h3 class="font-heading font-bold text-gray-900 mb-2">Core Subjects</h3>
          <p class="text-gray-600 text-sm">Comprehensive curriculum covering all essential academic domains</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <div class="text-4xl font-bold text-primary-500 mb-2">Modern</div>
          <h3 class="font-heading font-bold text-gray-900 mb-2">Teaching Methods</h3>
          <p class="text-gray-600 text-sm">Blending traditional excellence with contemporary educational approaches</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BNCC Program Section -->
  <section id="bncc" class="py-16 md:py-24 bg-gray-900">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-accent-500 text-white px-4 py-1.5 rounded-full text-xs font-bold mb-6 tracking-wide">Only in Badda</div>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-6">Bangladesh National Cadet Corps</h2>
          <p class="text-gray-300 text-lg leading-relaxed mb-6">
            We are the only institution in Badda offering the prestigious BNCC program, providing tri-services volunteer reserve force training across Army, Navy, and Air Force branches.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-accent-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Military Training</h3>
                <p class="text-gray-400 text-sm">Professional training by experienced military staff</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-accent-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Leadership Development</h3>
                <p class="text-gray-400 text-sm">Cultivating leadership qualities and character building</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-accent-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Physical Fitness</h3>
                <p class="text-gray-400 text-sm">Comprehensive physical training and wellness programs</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-accent-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">National Service</h3>
                <p class="text-gray-400 text-sm">Instilling values of discipline, duty, and service to nation</p>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div class="bg-gray-800 rounded-lg p-4 text-center">
              <div class="text-2xl mb-2">🇧🇩</div>
              <p class="text-gray-300 text-xs font-semibold">Army</p>
            </div>
            <div class="bg-gray-800 rounded-lg p-4 text-center">
              <div class="text-2xl mb-2">🚢</div>
              <p class="text-gray-300 text-xs font-semibold">Navy</p>
            </div>
            <div class="bg-gray-800 rounded-lg p-4 text-center">
              <div class="text-2xl mb-2">✈️</div>
              <p class="text-gray-300 text-xs font-semibold">Air Force</p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl aspect-[4/3] overflow-hidden">
          <img src="/images/home/bncc.jpg" alt="BNCC Training Program at SMMM School" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Teaching Process Section -->
  <section id="teaching" class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Our Teaching Process</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">A holistic four-step approach to academic excellence and student development</p>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        <!-- Step 1 -->
        <div class="relative">
          <div class="flex flex-col h-full">
            <div class="flex items-center justify-center mb-6">
              <div class="w-16 h-16 bg-primary-500 rounded-full flex items-center justify-center text-white text-2xl font-bold font-heading">1</div>
            </div>
            <div class="bg-primary-50 rounded-xl p-6 flex-1">
              <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Interactive Learning</h3>
              <p class="text-gray-700 leading-relaxed text-sm">
                Engaging classroom discussions and participatory sessions that encourage students to think critically and ask questions.
              </p>
            </div>
          </div>
          <div class="hidden md:block absolute top-8 -right-4 w-8 h-8 text-primary-300">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative">
          <div class="flex flex-col h-full">
            <div class="flex items-center justify-center mb-6">
              <div class="w-16 h-16 bg-primary-600 rounded-full flex items-center justify-center text-white text-2xl font-bold font-heading">2</div>
            </div>
            <div class="bg-primary-100 rounded-xl p-6 flex-1">
              <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Practical Labs</h3>
              <p class="text-gray-700 leading-relaxed text-sm">
                Hands-on experimentation in state-of-the-art science and IT laboratories to reinforce theoretical concepts.
              </p>
            </div>
          </div>
          <div class="hidden md:block absolute top-8 -right-4 w-8 h-8 text-primary-300">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative">
          <div class="flex flex-col h-full">
            <div class="flex items-center justify-center mb-6">
              <div class="w-16 h-16 bg-primary-700 rounded-full flex items-center justify-center text-white text-2xl font-bold font-heading">3</div>
            </div>
            <div class="bg-primary-50 rounded-xl p-6 flex-1">
              <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Regular Assessment</h3>
              <p class="text-gray-700 leading-relaxed text-sm">
                Continuous evaluation through quizzes, assignments, and tests to track progress and identify areas for improvement.
              </p>
            </div>
          </div>
          <div class="hidden md:block absolute top-8 -right-4 w-8 h-8 text-primary-300">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="relative">
          <div class="flex flex-col h-full">
            <div class="flex items-center justify-center mb-6">
              <div class="w-16 h-16 bg-primary-800 rounded-full flex items-center justify-center text-white text-2xl font-bold font-heading">4</div>
            </div>
            <div class="bg-primary-100 rounded-xl p-6 flex-1">
              <h3 class="text-xl font-heading font-bold text-gray-900 mb-3">Holistic Development</h3>
              <p class="text-gray-700 leading-relaxed text-sm">
                Beyond academics: character building, extracurricular activities, and mentorship for well-rounded growth.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Teaching Methodology Detail -->
      <div class="mt-16 bg-gradient-to-r from-primary-50 to-blue-50 rounded-2xl p-8 md:p-12">
        <div class="max-w-4xl">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Our Teaching Methodology</h3>
          <p class="text-gray-700 leading-relaxed mb-6">
            Our approach focuses on building a healthy human society and self-sufficient people through adaptation to modern scientific and technological advancement. We develop student thinking skills, imagination, curiosity, and creativity.
          </p>
          <div class="grid md:grid-cols-2 gap-x-8 gap-y-3">
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">Specific academic plans and daily lesson structures</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">Computers, projectors, and whiteboards in classrooms</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">Participatory learning and group discussions</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">Regular science practicals for hands-on learning</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">Computer lab and library for independent research</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">One-to-one instruction for struggling learners</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">No requirement for private tutoring or coaching</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-gray-700 text-sm">24/7 CCTV security and continuous power supply</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary-500 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Ready to Begin Your Academic Journey?</h2>
      <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">Join SMMM School and experience excellence in education with our comprehensive curriculum and world-class facilities.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/admissions" class="bg-white text-primary-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">Apply for Admission</a>
        <a href="/contact" class="border-2 border-white/40 px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
