---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | SMMM School">
  <section class="py-24 md:py-32 text-center">
    <div class="max-w-md mx-auto px-4">
      <div class="text-8xl font-heading font-bold text-primary-100 mb-4">404</div>
      <h1 class="text-2xl font-heading font-bold text-gray-900 mb-3">Page Not Found</h1>
      <p class="text-gray-600 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn-primary">Back to Home</a>
    </div>
  </section>
</BaseLayout>
