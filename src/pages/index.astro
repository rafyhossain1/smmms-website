---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Siraj Mia Memorial Model School | Quality Education Since 2005" description="Nurturing potential, building futures. Quality education at a reasonable price in Badda, Dhaka.">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-500 via-primary-600 to-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white rounded-full translate-y-1/3 -translate-x-1/4"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-3xl">
        <p class="text-blue-200 font-medium mb-3 tracking-wide uppercase text-sm">Est. 2005 &bull; ISO 9001 Certified</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
          Siraj Mia Memorial<br>Model School
        </h1>
        <p class="text-lg md:text-xl text-blue-100 leading-relaxed mb-8 max-w-2xl">
          Nurturing potential, building futures. Providing high-quality education
          at a reasonable price in the heart of Badda, Dhaka.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/admissions" class="bg-white text-primary-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">Apply Now</a>
          <a href="https://wa.me/8801822447288" target="_blank" rel="noopener" class="border-2 border-white/40 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Support
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Stats -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 -mt-8 relative z-10">
        <div class="bg-white rounded-xl shadow-lg p-5 text-center">
          <div class="text-2xl mb-1">&#127979;</div>
          <div class="text-2xl font-bold text-primary-500 font-heading">2005</div>
          <div class="text-sm text-gray-500 mt-1">Founded</div>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-5 text-center">
          <div class="text-2xl mb-1">&#127891;</div>
          <div class="text-2xl font-bold text-primary-500 font-heading">100%</div>
          <div class="text-sm text-gray-500 mt-1">SSC Pass Rate</div>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-5 text-center">
          <div class="text-2xl mb-1">&#9989;</div>
          <div class="text-2xl font-bold text-primary-500 font-heading">ISO</div>
          <div class="text-sm text-gray-500 mt-1">Certified</div>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-5 text-center">
          <div class="text-2xl mb-1">&#127894;</div>
          <div class="text-2xl font-bold text-primary-500 font-heading">BNCC</div>
          <div class="text-sm text-gray-500 mt-1">Only in Badda</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">Why Choose SMMM School?</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">We provide a holistic educational experience that prepares students for success.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">BNCC Program</h3>
          <p class="text-gray-600 text-sm leading-relaxed">The only institution in Badda offering the Bangladesh National Cadet Corps program. Students develop leadership, discipline, and physical fitness.</p>
        </div>

        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">Custom-Built Campus</h3>
          <p class="text-gray-600 text-sm leading-relaxed">A thoughtfully designed campus with spacious layout, a serene garden, and state-of-the-art science and IT labs.</p>
        </div>

        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">ISO Certified</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Certified by AJA and UKAS Management Systems under ISO 9001:2008. International standards verified by external body.</p>
        </div>

        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">Modern Technology</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Frequently upgraded infrastructure including advanced science and IT labs for the best educational resources.</p>
        </div>

        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">TEDx Host School</h3>
          <p class="text-gray-600 text-sm leading-relaxed">First Bangla medium school in Bangladesh to host a TEDx event — TEDxSMMMSchool in March 2024.</p>
        </div>

        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center text-primary-500 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">Community Service</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Active community engagement — distributed food and water to 1,200 families during the 2022 Sylhet floods.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Our Story Preview -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-primary-500 font-medium mb-2 uppercase tracking-wide text-sm">Our Story</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">A Legacy of Excellence Since 2005</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Founded in 2005 to honour the memory of Siraj Mia, the school was
            inaugurated on 13th January 2007 by Dr. Anwara Begum, wife of
            Dr. Iajuddin Ahmed, President of Bangladesh.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Our primary objective is to provide high-quality education at a
            reasonable price. We nurture every student's potential through
            dedicated teaching and a supportive learning environment.
          </p>
          <a href="/about" class="inline-block bg-primary-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors">Read Our Full Story</a>
        </div>
        <div class="rounded-2xl aspect-[4/3] overflow-hidden">
          <img src="/images/home/inauguration.jpg" alt="School inauguration ceremony, 13 January 2007" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary-500 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Ready to Join Our School?</h2>
      <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">Admissions are open for the upcoming academic year. Give your child the gift of quality education.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/admissions" class="bg-white text-primary-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">Apply for Admission</a>
        <a href="/contact" class="border-2 border-white/40 px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
