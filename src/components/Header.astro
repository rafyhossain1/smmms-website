---
const nav = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Academics', href: '/academics' },
  { label: 'Admissions', href: '/admissions' },
  { label: 'Campus Life', href: '/campus-life' },
  { label: 'News', href: '/blog' },
  { label: 'Alumni', href: '/alumni' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---

<!-- Top Bar -->
<div class="bg-primary-500 text-white text-sm py-1.5">
  <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
    <div class="flex items-center gap-4">
      <a href="tel:+8801822447288" class="flex items-center gap-1 hover:text-blue-200 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        +880 1822 447288
      </a>
      <span class="hidden sm:flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Badda, Dhaka 1212
      </span>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden md:inline">Sat-Thu: 9AM - 5PM</span>
      <a href="https://wa.me/8801822447288" target="_blank" rel="noopener" aria-label="WhatsApp" class="hover:text-blue-200 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <a href="https://www.facebook.com/SMMMS2005/" target="_blank" rel="noopener" aria-label="Facebook" class="hover:text-blue-200 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
    </div>
  </div>
</div>

<!-- Main Nav -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 py-3">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="/images/logo.jpg" alt="SMMM School Logo" class="w-10 h-10 rounded-full object-cover" />
        <div>
          <span class="font-heading font-bold text-lg text-gray-900 leading-tight block">SMMM School</span>
          <span class="text-xs text-gray-500 leading-tight block">Est. 2005</span>
        </div>
      </a>
      <div class="hidden lg:flex items-center gap-1">
        {nav.map((item) => (
          <a href={item.href} class:list={['px-3 py-2 rounded-md text-sm font-medium transition-colors', isActive(item.href) ? 'text-primary-500 bg-primary-50' : 'text-gray-600 hover:text-primary-500 hover:bg-gray-50']}>
            {item.label}
          </a>
        ))}
        <a href="/contact" class="ml-2 btn-primary text-sm !py-2 !px-4">Contact Us</a>
      </div>
      <button id="menu-btn" class="lg:hidden p-2 rounded-md text-gray-600 hover:bg-gray-100" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden lg:hidden mt-3 pb-3 border-t border-gray-100">
      <div class="flex flex-col gap-1 pt-3">
        {nav.map((item) => (
          <a href={item.href} class:list={['px-3 py-2.5 rounded-md text-sm font-medium', isActive(item.href) ? 'text-primary-500 bg-primary-50' : 'text-gray-600 hover:text-primary-500 hover:bg-gray-50']}>
            {item.label}
          </a>
        ))}
        <a href="/contact" class="btn-primary text-sm text-center mt-2">Contact Us</a>
      </div>
    </div>
  </nav>
</header>

<script>
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
